# kira-backend environment template — copy to `.env` (gitignored) and fill in.
# NEVER commit a real `.env`. This file contains placeholders only (PLAN hard-constraint 3, §6).
#
# For a quick local run you do NOT need most of these: use `docker compose up -d` and the `dev`
# Spring profile (SPRING_PROFILES_ACTIVE=dev), which reads the docker-compose DB coordinates from
# application-dev.yml directly.

# ── Database (used by the app OUTSIDE the `dev` profile; Spring Boot maps these env vars
#    straight onto spring.datasource.*). The URL + username below match docker-compose (host
#    port 5433); set the password to the compose throwaway (`kira`) for a local out-of-profile
#    run, or to your real DB password otherwise. Placeholder only — never commit a real secret
#    here (PLAN hard-constraint 3). Day-to-day local dev needs NONE of this: use the `dev`
#    profile, which reads the compose coordinates from application-dev.yml directly. ──────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/kira
SPRING_DATASOURCE_USERNAME=kira
SPRING_DATASOURCE_PASSWORD=change-me-local-only

# ── docker-compose overrides (optional; defaults are baked into docker-compose.yml) ────────
# POSTGRES_USER=kira
# POSTGRES_PASSWORD=change-me-local-only
# POSTGRES_DB=kira

# ── Introduced in later phases (documented here so the shape is known; NOT consumed yet in
#    the Phase-1 scaffold). Uncomment and set when those phases land. ─────────────────────
# JWT signing key — Base64 that decodes to >= 256 bits, e.g. `openssl rand -base64 32`
#   (NOT a human passphrase; PLAN §6). Startup fails fast if missing/short outside dev.
# KIRA_JWT_SECRET=

# Admin bootstrap credentials — required wherever admin seeding is enabled (PLAN §6).
#   The password is BCrypt-hashed at seed time and NEVER logged.
# KIRA_ADMIN_EMAIL=
# KIRA_ADMIN_PASSWORD=
