#!/usr/bin/env bash
set -euo pipefail

original=${SSH_ORIGINAL_COMMAND:-}
if [[ $original =~ ^deploy\ (backend|web)\ ([0-9a-f]{40})$ ]]; then
  exec sudo /usr/local/sbin/kira-deploy deploy "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
fi

printf 'Only Kira image deployment is permitted.\n' >&2
exit 64

