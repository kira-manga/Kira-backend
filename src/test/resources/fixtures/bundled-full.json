            { "value": "تحقيقات" }, { "value": "تخطيط" }, { "value": "تدريب" }, { "value": "تراجع" }, { "value": "تراجيدي" },
            { "value": "ترويض" }, { "value": "ترويض وحوش" }, { "value": "تشويق" }, { "value": "تلوين رسم" }, { "value": "تلوين رسمي" },
